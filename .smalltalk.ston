SmalltalkCISpec {
  #loading : [
    SCIMetacelloLoadSpec {
      #baseline : 'MCP',
      #directory : 'src',
      #ignoreImage : true,
      #onConflict : #useIncoming,
      #onUpgrade : #useIncoming
    }
  ],
  #testing : {
    #coverage : {
      #packages : [
        'MCP',
        'MCP-Spec'
      ],
      #format : #lcov
    }
  }
}
