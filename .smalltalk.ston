SmalltalkCISpec {
  #loading : [
    SCIMetacelloLoadSpec {
      #baseline : 'MCP',
      #ignoreImage : true,
      #onConflict : #useIncoming,
      #onUpgrade : #useIncoming
    }
  ],
  #testing : {
    #packages : [
      'MCP-Tests',
      'MCP-Spec-Tests'
    ],
    #coverage : {
      #packages : [
        'MCP',
        'MCP-Spec'
      ],
      #format : #lcov
    }
  }
}
